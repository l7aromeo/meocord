{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": "./dist/test",
    "types": ["node", "jest", "reflect-metadata"]
  },
  "include": ["src/**/*", "src/**/*.spec.ts"],
  "exclude": ["node_modules"]
}
